# Normalize text files (LF in the repository).
* text=auto

# Shell scripts must stay LF (Linux containers / Hugging Face Spaces).
*.sh text eol=lf

# Windows PowerShell scripts stay CRLF.
*.ps1 text eol=crlf

# Binary image assets via Git LFS (Hugging Face requires LFS/Xet for binaries).
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text

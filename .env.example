# Copy this file to ".env" and adjust if needed.
# All settings use the CREDDY_ prefix.

CREDDY_DB_HOST=localhost
CREDDY_DB_PORT=5432
CREDDY_DB_NAME=creddy
CREDDY_DB_USER=creddy
CREDDY_DB_PASSWORD=creddy
# Set to "require" for managed Postgres (Neon/Supabase); leave empty for local Docker.
CREDDY_DB_SSLMODE=

# Hard cap on the number of rows any single query may return.
CREDDY_QUERY_ROW_LIMIT=1000

# TCMB EVDS (live Turkish central-bank data).
# Get a free API key at https://evds3.tcmb.gov.tr  (register -> profile -> API key).
CREDDY_TCMB_API_KEY=
# Override only if/when the public REST endpoint changes:
CREDDY_TCMB_BASE_URL=https://evds3.tcmb.gov.tr/igmevdsms-dis
# EVDS3 site used by the live tcmb_indicators tool (no key required):
CREDDY_TCMB_SITE_URL=https://evds3.tcmb.gov.tr
